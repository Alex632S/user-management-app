{
  "name": "nuxt-app",
  "version": "1.2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:netlify": "cross-env NUXT_PUBLIC_NETLIFY_ENABLED=true nuxt build",
    "preview": "nuxt preview",
    "lint:staged": "node tests/scripts/run-tests.js",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "test": "vitest --run",
    "test:changed": "vitest related --run",
    "test:unit": "vitest --run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:format": "npm run format && npm run lint:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/yup": "^4.15.1",
    "nuxt": "^4.3.1",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.0.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@mswjs/data": "^0.16.2",
    "@netlify/nuxt": "^0.2.24",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.3.3",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "node-fetch": "^3.3.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^5.2.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
